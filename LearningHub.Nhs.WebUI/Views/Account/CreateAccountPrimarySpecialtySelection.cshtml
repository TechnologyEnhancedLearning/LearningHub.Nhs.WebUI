@using elfhHub.Nhs.Models.Common
@model LearningHub.Nhs.WebUI.Models.Account.AccountCreationListViewModel


@{
    ViewData["Title"] = "Primary Specialty";
    ViewData["DisableValidation"] = true;
    var errorHasOccurred = !ViewData.ModelState.IsValid;
    string grade = !string.IsNullOrWhiteSpace(Context.Request.Query["gradeId"]) ? Context.Request.Query["gradeId"] : Model.GradeId;
    string regNo = !string.IsNullOrWhiteSpace(Context.Request.Query["registrationNumber"]) ? Context.Request.Query["registrationNumber"] : Model.RegistrationNumber;
    var routeData = new Dictionary<string, string> { { "gradeId", grade } };
    var emptyResultRouteData = new Dictionary<string, string> { { "registrationNumber", regNo } };
    bool returnToConfirmation = false;
    if (!string.IsNullOrWhiteSpace(Context.Request.Query["returnToConfirmation"]))
    {
        bool.TryParse(Context.Request.Query["returnToConfirmation"].ToString(), out returnToConfirmation);
    }
}

@section styles {
    <link rel="stylesheet" type="text/css" href="~/css/nhsuk/pages/createaccount.css" asp-append-version="true" />
}
<div class="create-account">
    <div class="nhsuk-width-container app-width-container">
        <div class="nhsuk-grid-row">
            <div class="nhsuk-grid-column-full @(returnToConfirmation ? "nhsuk-u-padding-top-7":string.Empty) nhsuk-u-padding-bottom-9">
                @if (Model.SpecialtyList.Any())
                {
                    @if (!returnToConfirmation)
                    {
                        if (!string.IsNullOrWhiteSpace(Model.PrimarySpecialtyId))
                        {
                            <vc:back-link asp-controller="Account" asp-action="UserProfileTasks" asp-all-route-data="@routeData" link-text="Back link" />
                        }
                        else
                        {
                            <vc:back-link asp-controller="Account" asp-action="CreateAccountPrimarySpecialty" asp-all-route-data="@routeData" link-text="Back to: Search for your primary specialty" />
                        }

                    }
                    @if (errorHasOccurred)
                    {
                        <vc:error-summary order-of-property-names="@(new[] { nameof(Model.FilterText) })" />
                    }
                    <h1 class="nhsuk-heading-xl">Search results for @Model.FilterText</h1>
                    <div class="nhsuk-grid-column-two-thirds nhsuk-u-padding-left-0">
                        <form asp-controller="Account" asp-action="CreateAccountPrimarySpecialtySelection" method="get" id="specialtyForm">
                            <input type="hidden" name="formSubmission" value="true">
                            <input type="hidden" name="GradeId" value="@Context.Request.Query["GradeId"]">
                            <input type="hidden" name="returnToConfirmation" value="@Context.Request.Query["returnToConfirmation"]">
                            <input type="hidden" name="RegistrationNumber" value="@Context.Request.Query["RegistrationNumber"]">
                            <input type="hidden" id="Currentspecialty" name="PrimarySpecialtyId" value="@Model.PrimarySpecialtyId" />
                            <label class="nhsuk-label nhsuk-u-visually-hidden" for="FilterText">Search results for @Model.FilterText</label>
                            <div class="nhsuk-form-group search-box-container" style="white-space:nowrap">
                                <input class="nhsuk-input nhsuk-search__input input-right-border" type="search" autocomplete="off" id="FilterText" name="FilterText" placeholder="" value="@Model.FilterText">
                            </div>

                            <!-- Search results -->
                            <div id="specialty-results-container" class="nhsuk-form-group nhsuk-u-margin-top-4" @(Model.SpecialtyList.Any() ? "" : "hidden")>
                                <fieldset class="nhsuk-fieldset" aria-describedby="specialty-results-hint">
                                    <legend class="nhsuk-fieldset__legend nhsuk-u-visually-hidden">
                                        Select your primary specialty
                                    </legend>

                                    <div class="nhsuk-radios" id="specialty-results">
                                        @if (Model.SpecialtyList.Any())
                                        {
                                            foreach (var specialty in Model.SpecialtyList)
                                            {
                                                var specialtyId = $"specialty-{specialty.Id}";
                                                var isChecked = Model.CurrentRole == specialty.Id.ToString();

                                                <div class="nhsuk-radios__item autocomplete-radio-item">
                                                    <input class="nhsuk-radios__input specialty-radio"
                                                           id="@specialtyId"
                                                           name="specialtyChoice"
                                                           type="radio"
                                                           value="@specialty.Id"
                                                           data-text="@specialty.Name"
                                                    @(isChecked ? "checked" : "") />

                                                    <label class="nhsuk-label nhsuk-radios__label" for="@specialtyId">
                                                        <strong>@specialty.Name</strong>
                                                    </label>
                                                </div>
                                            }
                                        }
                                    </div>
                                </fieldset>
                            </div>

                            <!-- Other option -->
                            <div class="nhsuk-form-group nhsuk-u-margin-top-5" id="other-specialty-group">
                                <fieldset class="nhsuk-fieldset">
                                    <legend class="nhsuk-fieldset__legend nhsuk-body">
                                        If you can't find your specialty select other
                                    </legend>

                                    <div class="nhsuk-radios" data-module="nhsuk-radios">
                                        <div class="nhsuk-radios__item">
                                            <input class="nhsuk-radios__input"
                                                   id="specialty-other"
                                                   name="specialtyChoice"
                                                   type="radio"
                                                   value="0"
                                                   data-aria-controls="specialty-other" />


                                            <label class="nhsuk-label nhsuk-radios__label" for="specialty-other">
                                                Other
                                            </label>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                            <div class="nhsuk-form-group">

                                <button class="nhsuk-button" type="submit">Continue</button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
 <script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("specialtyForm");
        const input = document.getElementById("FilterText");
        const resultsContainer = document.getElementById("specialty-results-container");
        const results = document.getElementById("specialty-results");
        const currentspecialty = document.getElementById("Currentspecialty");
        const otherRadio = document.getElementById("specialty-other");
        const searchGroup = document.getElementById("search-group");

        let debounceTimer = null;

          function clearspecialtySelection() {
        document.querySelectorAll(".specialty-radio").forEach(radio => {
            radio.checked = false;
        });

        currentspecialty.value = "";
    }
        function selectSuggestedspecialty(specialtyId, specialtyText) {
            currentspecialty.value = specialtyId;

            // Clear Other
            if (otherRadio) {
                otherRadio.checked = false;
            }

            input.value = specialtyText;
        }

        function bindspecialtyRadioEvents() {
            const specialtyRadios = document.querySelectorAll(".specialty-radio");

            specialtyRadios.forEach(radio => {
                radio.addEventListener("change", function () {
                    if (this.checked) {
                        const specialtyId = this.value;
                        const specialtyText = this.getAttribute("data-text") || "";
                        selectSuggestedspecialty(specialtyId, specialtyText);
                    }
                });
            });
        }

          function renderResults(data) {
        results.innerHTML = "";

        if (!data || data.length === 0) {
            resultsContainer.hidden = true;
            return;
        }

        data.forEach(specialty => {
            const item = document.createElement("div");
            item.className = "nhsuk-radios__item autocomplete-radio-item";

            const radioId = "specialty-" + specialty.id;

            item.innerHTML = `
                <input class="nhsuk-radios__input specialty-radio"
                       id="${radioId}"
                       name="specialtyChoice"
                       type="radio"
                       value="${specialty.id}"
                       data-text="${specialty.text}" />
                <label class="nhsuk-label nhsuk-radios__label" for="${radioId}">
                    <strong>${specialty.text}</strong>
                    ${specialty.category ? '<span class="nhsuk-hint">' + specialty.category + '</span>' : ''}
                </label>
            `;

            results.appendChild(item);
        });

        resultsContainer.hidden = false;
        bindspecialtyRadioEvents();
    }

        function searchspecialtys() {
            const term = input.value.trim();

            // If user starts searching again, clear current selected specialty
            clearspecialtySelection();

            if (term.length < 2) {
                results.innerHTML = "";
                resultsContainer.hidden = true;
                return;
            }

            fetch(`/Account/Searchspecialtys?term=${encodeURIComponent(term)}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Search request failed.");
                    }
                    return response.json();
                })
                .then(data => {
                    renderResults(data);
                })
                .catch(error => {
                    console.error("specialty search failed:", error);
                    results.innerHTML = "";
                    resultsContainer.hidden = true;
                });
        }

        // Initial binding for server-rendered radios
        bindspecialtyRadioEvents();

        // If Other is already selected on page load
        if (otherRadio && otherRadio.checked) {
           // toggleOtherConditional(true);
        }

        //trigger autosuggest
            input.addEventListener("input", function () {
        clearTimeout(debounceTimer);

        debounceTimer = setTimeout(() => {
            const term = input.value.trim();

            if (term.length < 2) {
                results.innerHTML = "";
                resultsContainer.hidden = true;
                return;
            }

            searchspecialtys();
        }, 300);
    });

         input.addEventListener("keydown", function (e) {
         if (e.key === "Enter") {
             e.preventDefault();

            // force search instead of submit
            searchspecialtys();
        }
    });

        // Other selected
           if (otherRadio) {
        otherRadio.addEventListener("change", function () {
            if (this.checked) {
                document.querySelectorAll(".specialty-radio").forEach(radio => {
                    radio.checked = false;
                });

                currentspecialty.value = "";
                input.value = "";
                results.innerHTML = "";
                resultsContainer.hidden = true;
            }
        });
    }

    if (form) {
        form.addEventListener("submit", function (e) {
            const selectedSuggestion = currentspecialty.value.trim();
            const selectedOther = otherRadio.checked;

            if (!selectedSuggestion && !selectedOther) {
                e.preventDefault();
                showClientError("FilterText");
                return;
            }

            if (otherRadio.checked) {
                currentspecialty.value = "0";
            }
        });
    }
    });
</script> 