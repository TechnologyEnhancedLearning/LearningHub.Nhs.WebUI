@model LearningHub.Nhs.WebUI.Models.Report.CourseCompletionViewModel

@{
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<style>
    .nhsuk-table-responsive-wrapper {
        overflow-x: auto;
        width: 100%;
    }

    .nhsuk-table-responsive {
        font-size: 0.75rem; /* Smaller base font */
        min-width: 100%;
        border-collapse: collapse;
    }

    .nhsuk-table__cell,
    .nhsuk-table__head th {
        padding: 4px 8px; /* Reduce cell padding */
        white-space: nowrap; /* Prevent wrapping */
    }

    .nhsuk-table-responsive__heading {
        font-size: 0.7rem; /* Smaller responsive heading */
        font-weight: bold;
    }

    .table-content-spacing {
        font-size: 0.75rem;
    }


</style>

@if (Model.TotalCount > 0)
{
    <div class="nhsuk-table-responsive-wrapper">
    <table role="table" class="nhsuk-table-responsive">
        <thead role="rowgroup" class="nhsuk-table__head">
            <tr role="row">
                <th role="columnheader" class="" scope="col">
                    Username
                </th>
                <th role="columnheader" class="" scope="col">
                    First name
                </th>
                <th role="columnheader" class="" scope="col">
                    Last name
                </th>
                <th role="columnheader" class="" scope="col">
                    Email address
                </th>
                <th role="columnheader" class="" scope="col">
                    Alt email address
                </th>
                
                <th role="columnheader" class="" scope="col">
                    Role
                </th>
                <th role="columnheader" class="" scope="col">
                    Location
                </th>
                <th role="columnheader" class="" scope="col">
                    Payroll employee number
                </th>
                <th role="columnheader" class="" scope="col">
                    ESR Number
                </th>
                <th role="columnheader" class="" scope="col">
                    Speciality reference
                </th>
                <th role="columnheader" class="" scope="col">
                    Organisation
                </th>
                <th role="columnheader" class="" scope="col">
                    TISID
                </th>
                <th role="columnheader" class="" scope="col">
                    NHSP UniqueID
                </th>
                <th role="columnheader" class="" scope="col">
                    Course
                </th>
                <th role="columnheader" class="" scope="col">
                    Course start date
                </th>
                <th role="columnheader" class="" scope="col">
                    Course completion date
                </th>
                <th role="columnheader" class="" scope="col">
                    Course duration
                </th>
                <th role="columnheader" class="" scope="col">
                    Status
                </th>
            </tr>
        </thead>
            <tbody class="nhsuk-table__body">
                @foreach (var entry in Model.CourseCompletionRecords)
                {
                    <tr role="row" class="nhsuk-table__row">

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Username</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.UserName</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">First name</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.FirstName</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Last name</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.LastName</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Email address</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.Email</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Alt email address</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.AltEmail</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Role</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.Role</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Location</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.Location</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Payroll employee number</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.PayrollEmployeeNumber</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">ESR Number</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.ESRNumber</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Speciality reference</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.SpecialityReference</span>
                        </td>                     

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Organisation</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.Organisation</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">TISID</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.TISID</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">NHSP UniqueID</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.NHSPUniqueID</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Course</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.Course</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Course start date</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.CourseStartDate</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Course completion date</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.CourseCompletionDate</span>
                        </td>

                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Course duration</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">@entry.CourseDuration</span>
                        </td>


                        <td role="cell" class="nhsuk-table__cell nhsuk-u-font-size-16">
                            <span class="nhsuk-table-responsive__heading">Status</span>
                            <span class="nhsuk-u-text-align-left table-content-spacing">
                                @ViewActivityHelper.GetReportStatusDisplayText(entry.CourseStatus)
                            </span>
                        </td>

                    </tr>
                }
            
            </tbody>
    </table>
    </div>
}
