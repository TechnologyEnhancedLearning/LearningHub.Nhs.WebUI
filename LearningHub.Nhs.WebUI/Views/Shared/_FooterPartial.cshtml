@inject LearningHub.Nhs.Caching.ICacheService cacheService
@using Microsoft.Extensions.Options;
@using LearningHub.Nhs.WebUI.Configuration;
@inject IOptions<Settings> settings;
@using NHSUKFrontendRazor.ViewModels;

@{
  var supportSiteUrl = settings.Value.SupportUrls.SupportSite;
  var footerGroupData = new List<FooterItemGroupModel>
  {
    new FooterItemGroupModel(
      new List<LinkViewModel>
      {
        new LinkViewModel(linkText: "Help", url: supportSiteUrl),
        new LinkViewModel(linkText: "Contact us", aspController: "Home", aspAction: "Contactus"),
        new LinkViewModel(linkText: "About us", aspController: "Home",  aspAction: "AboutUs"),
        new LinkViewModel(linkText: "Service updates and releases", aspController: "Updates",  aspAction: "Index"),
        new LinkViewModel(linkText: "NHS sites", aspController: "Home",  aspAction: "Index"),
        new LinkViewModel(linkText: "Our policies", aspController: "Policies",  aspAction: "Index"),
        new LinkViewModel(linkText: "Accessibility statement", aspController: "Home",  aspAction: "Accessibility")
      },
      true
    )
  };
}

<vc:footer copyright="© NHS England 2024"
           footer-group-list="@footerGroupData"
           is-vertically-aligned="true" />