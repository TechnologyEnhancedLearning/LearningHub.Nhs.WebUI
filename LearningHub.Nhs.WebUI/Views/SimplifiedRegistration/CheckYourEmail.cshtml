@model string
@{
    ViewData["Title"] = "Check your email";
    ViewData["DisableValidation"] = true;
}
@section styles{
    <link rel="stylesheet" type="text/css" href="~/css/nhsuk/pages/createaccount.css" asp-append-version="true" />
}
<div class="create-account">
    <div class="nhsuk-width-container app-width-container">
        <div class="nhsuk-grid-row">
            <div class="nhsuk-grid-column-one-half nhsuk-u-padding-top-8">
                <h1>Check your email</h1>
                <p>
                    We've emailed a verification link to <b>@Model</b>
                </p>
                <ul class="nhsuk-list nhsuk-list--bullet">
                    <li>Open the email and select the link to confirm your account.</li>
                    <li>Check your spam or junk folder if the email has not arrived in the next 30 minutes.</li>
                    <li>The link expires in <b>4 hours.</b></li>
                </ul>
@*                 <div>
                    <a asp-controller="" asp-action="" class="nhsuk-button">Resend email verification</a>
                </div> *@
                <p>
                    If you need to change your email, you'll need to  <a asp-controller="SimplifiedRegistration" asp-action="CreateAnAccount">start again</a>
                </p>
            </div>
            <div class="nhsuk-grid-column-one-half nhsuk-u-padding-top-8">
            </div>
           
        </div>
    </div>
</div>
