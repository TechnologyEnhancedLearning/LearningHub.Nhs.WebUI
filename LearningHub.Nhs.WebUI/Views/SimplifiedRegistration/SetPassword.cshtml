@using LearningHub.Nhs.WebUI.Models.SimplifiedRegistration
@using Microsoft.Extensions.Options;
@using LearningHub.Nhs.WebUI.Configuration;
@model PasswordValidateViewModel;
@inject IOptions<Settings> settings

@{
    ViewData["Title"] = "Set a password";
    ViewData["DisableValidation"] = true;
    var errorHasOccurred = !ViewData.ModelState.IsValid;
}
@section styles{
    <link rel="stylesheet" type="text/css" href="~/css/nhsuk/pages/createaccount.css" asp-append-version="true" />
}
<div class="create-account">
    <div class="nhsuk-width-container app-width-container">
        <div class="nhsuk-grid-row">
            <div class="nhsuk-grid-column-one-half nhsuk-u-padding-top-8">

                <form class="nhsuk-u-margin-bottom-2" asp-controller="SimplifiedRegistration" asp-action="SetPassword" method="post">
                    @if (errorHasOccurred)
                    {
                        <vc:error-summary order-of-property-names="@(new[] { nameof(Model.NewPassword),nameof(Model.PasswordConfirmation) })" />
                    }

                    <h1 class="nhsuk-heading-xl">Set a password</h1>
                    <div class="nhsuk-hint nhsuk-u-padding-bottom-2" id="contact-hint">
                        <p>A password must be at least 8 characters with at least 1 uppercase letter, 1 lower case letter and 1 number</p>
                    </div>
                    <div>
                        <vc:text-input asp-for="NewPassword"
                                       label="Enter password"
                                       populate-with-current-value="false"
                                       type="password"
                                       spell-check="false"
                                       hint-text=""
                                       autocomplete=""
                                       css-class="nhsuk-u-width-full"
                                       required="true"
                                       required-client-side-error-message="Enter your new password" />
                        <vc:text-input asp-for="PasswordConfirmation"
                                       label="Re-enter password"
                                       populate-with-current-value="false"
                                       type="password"
                                       spell-check="false"
                                       hint-text=""
                                       autocomplete=""
                                       css-class="nhsuk-u-width-full"
                                       required="true"
                                       required-client-side-error-message="Enter your password again" />

                    </div>
                    <input type="hidden" name="Username" asp-for="@Model.Username" />
                    <input type="hidden" name="Token" asp-for="@Model.Token" />
                    <input type="hidden" name="LocToken" asp-for="@Model.Loctoken" />


                    <div class="nhsuk-u-padding-bottom-5">
                        <button class="nhsuk-button" data-module="nhsuk-button" type="submit">
                            Continue
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
